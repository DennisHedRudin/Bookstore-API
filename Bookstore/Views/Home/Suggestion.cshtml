@{
	ViewData["Title"] = "Suggest book";
}

<div class="container">
    <h2>Suggest book</h2>

    <input id="nameSuggestion" class="form-control mb-2" placeholder="Your name" />
    <input id="authorSuggestion" class="form-control mb-2" placeholder="Author" />
    <input id="titleSuggestion" class="form-control mb-2" placeholder="Title" />


    <button class="btn btn-success" onclick="suggestBook()">Suggest</button>

    <div id="suggestionResult" class="mt-3"></div>
</div>